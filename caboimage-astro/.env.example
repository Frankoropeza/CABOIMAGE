# ─── CABO IMAGE — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Site ──────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://caboimage.com
PUBLIC_SITE_NAME="Cabo Image"
PUBLIC_PHOTOGRAPHER_NAME="Miguel Ventura"

# ── Contact ───────────────────────────────────────────────────────────
PUBLIC_WHATSAPP_NUMBER="+52XXXXXXXXXX"
PUBLIC_EMAIL="miguel@caboimage.com"
PUBLIC_PHONE="+52-XXX-XXX-XXXX"

# ── Social Media ──────────────────────────────────────────────────────
PUBLIC_INSTAGRAM_URL="https://instagram.com/caboimage"
PUBLIC_FACEBOOK_URL="https://facebook.com/caboimage"
PUBLIC_INSTAGRAM_HANDLE="@caboimage"

# ── Forms (choose one provider) ───────────────────────────────────────
# Option A: Netlify Forms (no config needed if deployed on Netlify)
# Option B: Resend (email API)
RESEND_API_KEY=""
CONTACT_EMAIL_TO="miguel@caboimage.com"

# Option C: Formspree
PUBLIC_FORMSPREE_ID=""

# ── Analytics ─────────────────────────────────────────────────────────
# Umami (privacy-first analytics)
PUBLIC_UMAMI_WEBSITE_ID=""
PUBLIC_UMAMI_SRC=""

# Google Analytics (optional)
PUBLIC_GA_MEASUREMENT_ID=""

# ── Image CDN (optional) ──────────────────────────────────────────────
# If using Cloudinary for image hosting
PUBLIC_CLOUDINARY_CLOUD_NAME=""
PUBLIC_CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Maps ──────────────────────────────────────────────────────────────
PUBLIC_GOOGLE_MAPS_KEY=""
