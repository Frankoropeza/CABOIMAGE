{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*":            ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*":    ["./src/layouts/*"],
      "@styles/*":     ["./src/styles/*"],
      "@content/*":    ["./src/content/*"],
      "@utils/*":      ["./src/utils/*"],
      "@types/*":      ["./src/types/*"]
    }
  }
}
