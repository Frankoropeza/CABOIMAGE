---
// FAQIndex.astro — Preguntas frecuentes en acordeón nativo HTML
// Sin JavaScript. details/summary nativos del browser.

const faqs = [
  {
    q: '¿Con cuánta anticipación debo reservar mi sesión de boda?',
    a: 'Para bodas en temporada alta (noviembre–mayo) recomendamos reservar con al menos 12–18 meses de anticipación, ya que los venues más exclusivos de Los Cabos se agotan rápidamente. Para fechas fuera de temporada o sesiones de retrato, 3–6 meses es suficiente.',
  },
  {
    q: '¿Qué incluye un paquete de fotografía de boda?',
    a: 'Todos los paquetes incluyen: cobertura completa del día (getting ready, ceremonia y recepción), edición profesional de todas las imágenes seleccionadas, galería privada online en alta resolución con acceso de descarga ilimitado, y derechos de uso personal de las fotos. Los paquetes específicos y horas de cobertura los definimos juntos en la consulta inicial.',
  },
  {
    q: '¿En qué formato y resolución recibo mis fotografías?',
    a: 'Recibes todas las imágenes en formato JPEG de alta resolución, listas para impresión en cualquier tamaño. La galería digital tiene acceso por 2 años y puedes descargar todas las fotos cuando gustes. También ofrecemos opciones de impresión de fine art y álbumes de lujo.',
  },
  {
    q: '¿Cubres bodas fuera de Los Cabos?',
    a: 'Sí. Miguel Ventura cubre bodas de destino en toda Baja California Sur — La Paz, Loreto, Todos Santos — y también acepta proyectos en el resto de México y el extranjero. Los costos de viaje se calculan por separado según la ubicación.',
  },
  {
    q: '¿También haces fotografía de compromiso (engagement)?',
    a: 'Absolutamente. Las sesiones de compromiso son una excelente oportunidad para conocerse antes de la boda, practicar frente a la cámara y obtener imágenes para las invitaciones o decoración del evento. Muchos de nuestros paquetes de boda las incluyen o permiten añadirlas.',
  },
  {
    q: '¿Cuánto tiempo tarda la entrega de las fotografías?',
    a: 'Las fotografías de boda se entregan en un plazo de 4–6 semanas después del evento. Para sesiones de retrato o comerciales, el tiempo de entrega es de 1–2 semanas. Si tienes una fecha límite específica, comunícala al momento de la reserva.',
  },
];

// JSON-LD para FAQ Schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section class="fq" aria-label="Preguntas frecuentes">
  <div class="fq__inner">

    <!-- Header 2 col: izq título, der acordeón -->
    <div class="fq__layout">

      <!-- Izquierda -->
      <div class="fq__left">
        <p class="fq__eyebrow">FAQ</p>
        <h2 class="fq__title">Preguntas frecuentes</h2>
        <p class="fq__subtitle">
          Respondemos las preguntas más comunes sobre nuestros servicios, paquetes y proceso de trabajo.
        </p>
        <a href="/contact" class="fq__cta">
          Hacer una pregunta
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Derecha: acordeón -->
      <div class="fq__right">
        {faqs.map((faq, i) => (
          <details class="fq__item" name="faq-group">
            <summary class="fq__question">
              <span>{faq.q}</span>
              <span class="fq__icon" aria-hidden="true">
                <svg class="fq__icon-plus" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                <svg class="fq__icon-minus" width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 8h10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
              </span>
            </summary>
            <div class="fq__answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>

    </div>

  </div>
</section>

<!-- FAQ Schema -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
/* ── FAQ INDEX ──────────────────────────────────────────────────────────── */

.fq {
  background-color: #0D0D0D;
  padding: clamp(4rem, 8vw, 6rem) 0;
  border-top: 1px solid #1A1A1A;
}

.fq__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

@media (min-width: 1024px) {
  .fq__inner { padding: 0 2.5rem; }
}

/* Layout */
.fq__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(2.5rem, 5vw, 5rem);
  align-items: start;
}

@media (min-width: 1024px) {
  .fq__layout { grid-template-columns: 1fr 1.6fr; }
}

/* Left */
.fq__eyebrow {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C8A97E;
  margin: 0 0 1rem;
}

.fq__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(1.875rem, 3vw, 2.5rem);
  font-weight: 300;
  color: #F5F0EB;
  margin: 0 0 1rem;
  line-height: 1.15;
}

.fq__subtitle {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.875rem;
  color: #6B6B6B;
  line-height: 1.75;
  margin: 0 0 2rem;
  max-width: 36ch;
}

.fq__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #C8A97E;
  text-decoration: none;
  border-bottom: 1px solid rgba(200,169,126,.3);
  padding-bottom: 0.2rem;
}

.fq__cta:hover {
  color: #D9C09D;
  border-bottom-color: #C8A97E;
}

/* Accordion */
.fq__item {
  border-bottom: 1px solid #1A1A1A;
}

.fq__item:first-child {
  border-top: 1px solid #1A1A1A;
}

.fq__question {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.25rem 0;
  cursor: pointer;
  list-style: none;
  font-family: 'Inter', system-ui, sans-serif;
  font-size: clamp(0.875rem, 1.1vw, 0.9375rem);
  font-weight: 500;
  color: #F5F0EB;
  line-height: 1.5;
  user-select: none;
}

.fq__question::-webkit-details-marker { display: none; }

.fq__question:hover {
  color: #C8A97E;
}

/* Ícono +/- */
.fq__icon {
  flex-shrink: 0;
  color: #C8A97E;
  margin-top: 0.1rem;
  position: relative;
  width: 16px;
  height: 16px;
}

.fq__icon-plus,
.fq__icon-minus {
  position: absolute;
  top: 0;
  left: 0;
}

.fq__icon-minus { display: none; }

details[open] .fq__icon-plus  { display: none; }
details[open] .fq__icon-minus { display: block; }
details[open] .fq__question   { color: #C8A97E; }

/* Answer */
.fq__answer {
  padding-bottom: 1.25rem;
}

.fq__answer p {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.875rem;
  color: #6B6B6B;
  line-height: 1.8;
  margin: 0;
  max-width: 64ch;
}
</style>
