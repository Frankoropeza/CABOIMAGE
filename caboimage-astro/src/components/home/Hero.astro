---
// Hero.astro — Patrón homologado MESECI / PROYECTORED
// Grid 55% / 1fr · H1 2 líneas sin breaks cortos · peso 600 · clamp profesional
---

<section class="hi" aria-label="Hero principal">
  <div class="container hi__grid">

    <!-- ── Columna izquierda: copy principal ── -->
    <div class="hi__left">

      <div class="hi__badge" aria-hidden="true">
        <span class="hi__dot"></span>
        Los Cabos, Baja California Sur
      </div>

      <h1 class="hi__h1">
        Fotografía de Bodas<br />
        <em class="hi__accent">& Eventos en Los Cabos</em>
      </h1>

      <p class="hi__sub">
        by Miguel Ventura — Más de 12 años documentando bodas y momentos únicos en Los Cabos con una visión artística que transforma instantes en imágenes permanentes.
      </p>

      <div class="hi__ctas">
        <a href="/services/wedding-photography" class="hi__btn hi__btn--primary">
          Ver portafolio de bodas
        </a>
        <a href="/contact" class="hi__btn hi__btn--ghost">
          Agendar consulta
        </a>
      </div>

      <div class="hi__trust" aria-label="Venues destacados">
        <span class="hi__trust-item">One&Only Palmilla</span>
        <span class="hi__trust-sep" aria-hidden="true">·</span>
        <span class="hi__trust-item">Capella Pedregal</span>
        <span class="hi__trust-sep" aria-hidden="true">·</span>
        <span class="hi__trust-item">Esperanza Auberge</span>
      </div>

    </div>

    <!-- ── Columna derecha: editorial SEO ── -->
    <div class="hi__right">
      <p class="hi__ed-eyebrow">Fotografía profesional</p>
      <p class="hi__ed-body">
        Cada boda es una historia única. Capturamos cada detalle, cada emoción y cada instante irrepetible con una visión artística que transforma momentos en imágenes duraderas.
      </p>
      <p class="hi__ed-body">
        Especializados en fotografía de bodas, retratos, bienes raíces, arquitectura, fine art y fotografía comercial en todo Baja California Sur.
      </p>
      <ul class="hi__tags" aria-label="Servicios">
        <li class="hi__tag">Bodas</li>
        <li class="hi__tag">Retratos</li>
        <li class="hi__tag">Bienes Raíces</li>
        <li class="hi__tag">Arquitectura</li>
        <li class="hi__tag">Fine Art</li>
        <li class="hi__tag">Comercial</li>
      </ul>
    </div>

  </div>
</section>

<style>
/* ── HERO ───────────────────────────────────────────────────────────────── */

.hi {
  padding-top: clamp(3rem, 5vw, 4.5rem);
  padding-bottom: clamp(3rem, 5vw, 4.5rem);
  background-color: #080808;
  color: #fff;
  position: relative;
  overflow: hidden;
}

/* Container — alineado con el resto del sitio */
.container {
  max-width: 1440px;
  margin: 0 auto;
  padding-left: 1.5rem;
  padding-right: 1.5rem;
}

@media (min-width: 1024px) {
  .container { padding-left: 2.5rem; padding-right: 2.5rem; }
}

/* Grid: 55% izquierda / resto derecha — igual que MESECI */
.hi__grid {
  display: grid;
  grid-template-columns: 55% 1fr;
  gap: clamp(2.5rem, 5vw, 5rem);
  align-items: center;
  min-height: auto;
}

@media (max-width: 1024px) {
  .hi__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
    min-height: auto;
    padding-top: 2.5rem;
    padding-bottom: 2.5rem;
  }
}

/* ── BADGE ──────────────────────────────────────────────────────────────── */

.hi__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border: 1px solid rgba(200,169,126,.45);
  background: rgba(200,169,126,.08);
  color: rgba(245,240,235,.85);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  padding: 0.3125rem 0.875rem;
  border-radius: 100px;
  margin-bottom: 1.75rem;
  font-family: 'Inter', system-ui, sans-serif;
}

.hi__dot {
  width: 6px;
  height: 6px;
  background: #C8A97E;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── H1 ─────────────────────────────────────────────────────────────────── */

.hi__h1 {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.25rem, 4vw, 3.5rem);
  font-weight: 500;
  line-height: 1.1;
  letter-spacing: -0.025em;
  color: #F5F0EB;
  margin: 0 0 1.375rem;
}

.hi__accent {
  font-style: italic;
  color: #C8A97E;
}

/* ── SUBTÍTULO ──────────────────────────────────────────────────────────── */

.hi__sub {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: clamp(0.875rem, 1.1vw, 1rem);
  color: rgba(245,240,235,.6);
  line-height: 1.75;
  max-width: 52ch;
  margin: 0 0 2rem;
}

/* ── CTAs ───────────────────────────────────────────────────────────────── */

.hi__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 2.25rem;
}

.hi__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.8125rem 1.625rem;
  border-radius: 2px;
}

.hi__btn--primary {
  background: #C8A97E;
  color: #080808;
  border: 1px solid #C8A97E;
}

.hi__btn--primary:hover {
  background: #D9C09D;
  border-color: #D9C09D;
}

.hi__btn--ghost {
  background: transparent;
  color: rgba(245,240,235,.8);
  border: 1px solid rgba(245,240,235,.2);
}

.hi__btn--ghost:hover {
  border-color: rgba(245,240,235,.45);
  color: #F5F0EB;
}

/* ── TRUST ──────────────────────────────────────────────────────────────── */

.hi__trust {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem;
}

.hi__trust-item {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  color: #4A4A4A;
  letter-spacing: 0.04em;
}

.hi__trust-sep {
  color: #242424;
  font-size: 0.75rem;
}

/* ── COLUMNA DERECHA ────────────────────────────────────────────────────── */

.hi__right {
  display: flex;
  flex-direction: column;
  gap: 0;
}

@media (max-width: 1024px) {
  .hi__right { display: none; }
}

.hi__ed-eyebrow {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C8A97E;
  margin: 0 0 1.25rem;
}

.hi__ed-body {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.9375rem;
  color: rgba(245,240,235,.45);
  line-height: 1.8;
  margin: 0 0 1.125rem;
}

.hi__tags {
  list-style: none;
  padding: 0;
  margin: 1.5rem 0 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.hi__tag {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.625rem;
  letter-spacing: 0.08em;
  color: #4A4A4A;
  border: 1px solid #1E1E1E;
  padding: 0.25rem 0.625rem;
  border-radius: 2px;
}
</style>
