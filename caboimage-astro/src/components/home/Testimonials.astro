---
// Testimonials.astro — Reviews de clientes, cards enriquecidas
// Fondo ligeramente diferente, 3 cards con venue + rating + quote

import { getCollection } from 'astro:content';

const allT = await getCollection('testimonials');
const featured = allT
  .filter(t => t.data.featured)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Iniciales para avatar placeholder
function initials(name: string) {
  return name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
}
---

<section class="rv" aria-label="Testimonios de clientes">
  <div class="rv__inner">

    <!-- Header -->
    <div class="rv__header">
      <div class="rv__header-left">
        <p class="rv__eyebrow">Testimonios</p>
        <h2 class="rv__title">Lo que dicen las parejas</h2>
      </div>
      <div class="rv__stars-global" aria-label="Calificación promedio 5 de 5 estrellas">
        <div class="rv__stars-row" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => (
            <svg width="14" height="14" viewBox="0 0 14 14" fill="#C8A97E" aria-hidden="true">
              <path d="M7 1l1.62 3.28L12.5 4.9l-2.75 2.68.65 3.78L7 9.48 3.6 11.36l.65-3.78L1.5 4.9l3.88-.62z"/>
            </svg>
          ))}
        </div>
        <span class="rv__stars-label">5.0 promedio · 400+ bodas</span>
      </div>
    </div>

    <!-- Cards grid -->
    <div class="rv__grid" role="list">
      {featured.map(t => (
        <article class="rv__card" role="listitem">

          <!-- Quote mark decorativo -->
          <span class="rv__quote-deco" aria-hidden="true">"</span>

          <!-- Stars -->
          <div class="rv__stars" aria-label={`${t.data.rating} de 5 estrellas`} role="img">
            {Array.from({ length: t.data.rating }).map(() => (
              <svg width="12" height="12" viewBox="0 0 14 14" fill="#C8A97E" aria-hidden="true">
                <path d="M7 1l1.62 3.28L12.5 4.9l-2.75 2.68.65 3.78L7 9.48 3.6 11.36l.65-3.78L1.5 4.9l3.88-.62z"/>
              </svg>
            ))}
          </div>

          <!-- Venue -->
          {t.data.venue && (
            <p class="rv__venue">{t.data.venue}</p>
          )}

          <!-- Quote -->
          <blockquote class="rv__quote">
            <p>"{t.data.quote}"</p>
          </blockquote>

          <!-- Autor -->
          <footer class="rv__author">
            <div class="rv__avatar" aria-hidden="true">
              {initials(t.data.name)}
            </div>
            <div class="rv__author-info">
              <p class="rv__name">{t.data.name}</p>
              <p class="rv__location">{t.data.location}</p>
            </div>
          </footer>

        </article>
      ))}
    </div>

    <!-- Footer -->
    <div class="rv__footer">
      <a href="/about#testimonios" class="rv__link">
        Leer más testimonios
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
/* ── TESTIMONIOS ────────────────────────────────────────────────────────── */

.rv {
  background-color: #0A0A0A;
  padding: clamp(4rem, 8vw, 6rem) 0;
  border-top: 1px solid #1A1A1A;
}

.rv__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

@media (min-width: 1024px) {
  .rv__inner { padding: 0 2.5rem; }
}

/* Header */
.rv__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: clamp(2rem, 3.5vw, 3rem);
  flex-wrap: wrap;
}

.rv__eyebrow {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C8A97E;
  margin: 0 0 0.625rem;
}

.rv__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(1.875rem, 3vw, 2.5rem);
  font-weight: 300;
  color: #F5F0EB;
  margin: 0;
  line-height: 1.15;
}

/* Calificación global */
.rv__stars-global {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.375rem;
  flex-shrink: 0;
}

.rv__stars-row {
  display: flex;
  gap: 0.2rem;
}

.rv__stars-label {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  color: #6B6B6B;
  letter-spacing: 0.04em;
}

/* Grid */
.rv__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  background-color: #1A1A1A;
  border: 1px solid #1A1A1A;
}

@media (min-width: 768px) {
  .rv__grid { grid-template-columns: repeat(3, 1fr); }
}

/* Card */
.rv__card {
  background-color: #0A0A0A;
  padding: clamp(1.75rem, 2.5vw, 2.25rem) clamp(1.5rem, 2vw, 2rem);
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.rv__card:hover {
  background-color: #0D0D0D;
}

/* Quote deco */
.rv__quote-deco {
  position: absolute;
  top: 1rem;
  right: 1.5rem;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 6rem;
  line-height: 1;
  color: #C8A97E;
  opacity: 0.1;
  pointer-events: none;
  user-select: none;
}

/* Stars */
.rv__stars {
  display: flex;
  gap: 0.2rem;
}

/* Venue */
.rv__venue {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.625rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #C8A97E;
  margin: 0;
  opacity: 0.8;
}

/* Quote */
.rv__quote {
  margin: 0;
  flex: 1;
}

.rv__quote p {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(1rem, 1.3vw, 1.125rem);
  font-style: italic;
  font-weight: 300;
  line-height: 1.7;
  color: #F5F0EB;
  margin: 0;
}

/* Autor */
.rv__author {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  border-top: 1px solid #1A1A1A;
  padding-top: 1.25rem;
  margin-top: 0.5rem;
}

/* Avatar placeholder */
.rv__avatar {
  width: 2.25rem;
  height: 2.25rem;
  background: rgba(200,169,126,.1);
  border: 1px solid rgba(200,169,126,.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 0.875rem;
  color: #C8A97E;
  flex-shrink: 0;
}

.rv__name {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  color: #F5F0EB;
  margin: 0 0 0.2rem;
}

.rv__location {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  color: #4A4A4A;
  margin: 0;
  letter-spacing: 0.03em;
}

/* Footer */
.rv__footer {
  margin-top: clamp(2rem, 3vw, 2.5rem);
  display: flex;
  justify-content: center;
}

.rv__link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #C8A97E;
  text-decoration: none;
  border-bottom: 1px solid rgba(200,169,126,.3);
  padding-bottom: 0.2rem;
}

.rv__link:hover {
  color: #D9C09D;
  border-bottom-color: #C8A97E;
}
</style>
