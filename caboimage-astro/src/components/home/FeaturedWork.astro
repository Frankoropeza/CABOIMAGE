---
// FeaturedWork.astro — Portafolio destacado
// Grid editorial asimétrico: imagen grande + columna doble + columna triple

const categories = [
  { label: 'Todos',       active: true  },
  { label: 'Bodas',       active: false },
  { label: 'Retratos',    active: false },
  { label: 'Ceremonias',  active: false },
  { label: 'Detalles',    active: false },
];

const photos = [
  {
    src: '/images/gallery/weddings/wedding-photographer-los-cabos-10.avif',
    alt: 'Boda en Los Cabos — imagen principal',
    cat: 'Bodas',
    size: 'hero', // ocupa 2 filas
  },
  {
    src: '/images/gallery/weddings/brides/bride-photographer-los-cabos-04.avif',
    alt: 'Retrato de novia Los Cabos',
    cat: 'Retratos',
    size: 'normal',
  },
  {
    src: '/images/gallery/weddings/love/wedding-love-los-cabos-07.avif',
    alt: 'Pareja en Los Cabos al atardecer',
    cat: 'Bodas',
    size: 'normal',
  },
  {
    src: '/images/gallery/weddings/ceremony/wedding-ceremony-los-cabos-04.avif',
    alt: 'Ceremonia de boda en Los Cabos',
    cat: 'Ceremonias',
    size: 'wide', // horizontal
  },
  {
    src: '/images/gallery/weddings/bride-and-groom/bride-groom-portrait-los-cabos-03.avif',
    alt: 'Retrato de novios',
    cat: 'Retratos',
    size: 'normal',
  },
  {
    src: '/images/gallery/weddings/brides/bride-photographer-los-cabos-12.avif',
    alt: 'Detalle de novia',
    cat: 'Detalles',
    size: 'normal',
  },
];
---

<section class="fw" aria-label="Portafolio destacado">
  <div class="fw__inner">

    <!-- Header: título izquierda + filtros derecha -->
    <div class="fw__header">
      <div class="fw__header-left">
        <p class="fw__eyebrow">Portafolio</p>
        <h2 class="fw__title">Momentos que perduran</h2>
      </div>

      <!-- Filtros de categoría (decorativos, navegan a galería) -->
      <nav class="fw__filters" aria-label="Filtrar por categoría">
        {categories.map(c => (
          <a
            href={c.active ? '/gallery' : `/gallery/${c.label.toLowerCase()}`}
            class:list={['fw__filter', c.active && 'fw__filter--active']}
          >
            {c.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Mosaic grid -->
    <div class="fw__mosaic" role="list">

      <!-- Col 1: una imagen grande (hero) -->
      <div class="fw__col fw__col--hero" role="listitem">
        <a href="/gallery" class="fw__card fw__card--hero" aria-label="Ver galería de bodas">
          <img src={photos[0].src} alt={photos[0].alt} loading="lazy" decoding="async" class="fw__img" />
          <div class="fw__card-overlay"></div>
          <div class="fw__card-info">
            <span class="fw__card-cat">{photos[0].cat}</span>
          </div>
        </a>
      </div>

      <!-- Col 2: dos imágenes apiladas -->
      <div class="fw__col fw__col--stack">
        <a href="/gallery" class="fw__card fw__card--half" role="listitem" aria-label="Ver galería de retratos">
          <img src={photos[1].src} alt={photos[1].alt} loading="lazy" decoding="async" class="fw__img" />
          <div class="fw__card-overlay"></div>
          <div class="fw__card-info">
            <span class="fw__card-cat">{photos[1].cat}</span>
          </div>
        </a>
        <a href="/gallery" class="fw__card fw__card--half" role="listitem" aria-label="Ver galería">
          <img src={photos[2].src} alt={photos[2].alt} loading="lazy" decoding="async" class="fw__img" />
          <div class="fw__card-overlay"></div>
          <div class="fw__card-info">
            <span class="fw__card-cat">{photos[2].cat}</span>
          </div>
        </a>
      </div>

      <!-- Col 3: imagen wide + dos pequeñas -->
      <div class="fw__col fw__col--mixed">
        <a href="/gallery" class="fw__card fw__card--wide" role="listitem" aria-label="Ver galería de ceremonias">
          <img src={photos[3].src} alt={photos[3].alt} loading="lazy" decoding="async" class="fw__img" />
          <div class="fw__card-overlay"></div>
          <div class="fw__card-info">
            <span class="fw__card-cat">{photos[3].cat}</span>
          </div>
        </a>
        <div class="fw__sub-row">
          <a href="/gallery" class="fw__card fw__card--sm" role="listitem" aria-label="Ver galería">
            <img src={photos[4].src} alt={photos[4].alt} loading="lazy" decoding="async" class="fw__img" />
            <div class="fw__card-overlay"></div>
            <div class="fw__card-info">
              <span class="fw__card-cat">{photos[4].cat}</span>
            </div>
          </a>
          <a href="/gallery" class="fw__card fw__card--sm" role="listitem" aria-label="Ver galería">
            <img src={photos[5].src} alt={photos[5].alt} loading="lazy" decoding="async" class="fw__img" />
            <div class="fw__card-overlay"></div>
            <div class="fw__card-info">
              <span class="fw__card-cat">{photos[5].cat}</span>
            </div>
          </a>
        </div>
      </div>

    </div>

    <!-- Footer: CTA centrado -->
    <div class="fw__footer">
      <a href="/gallery" class="fw__cta">
        Explorar galería completa
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <p class="fw__footer-note">+400 fotografías disponibles en portafolio completo</p>
    </div>

  </div>
</section>

<style>
/* ── FEATURED WORK ──────────────────────────────────────────────────────── */

.fw {
  background-color: #080808;
  padding: clamp(4rem, 8vw, 6rem) 0;
}

.fw__inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

@media (min-width: 1024px) {
  .fw__inner { padding: 0 2.5rem; }
}

/* Header */
.fw__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: clamp(2rem, 3.5vw, 3rem);
  flex-wrap: wrap;
}

.fw__eyebrow {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C8A97E;
  margin: 0 0 0.625rem;
}

.fw__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(1.875rem, 3vw, 2.5rem);
  font-weight: 300;
  color: #F5F0EB;
  margin: 0;
  line-height: 1.15;
}

/* Filters */
.fw__filters {
  display: flex;
  gap: 0.25rem;
  flex-wrap: wrap;
}

.fw__filter {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  letter-spacing: 0.06em;
  color: #6B6B6B;
  text-decoration: none;
  padding: 0.375rem 0.875rem;
  border: 1px solid transparent;
  border-radius: 2px;
}

.fw__filter:hover,
.fw__filter--active {
  color: #C8A97E;
  border-color: rgba(200,169,126,.3);
  background: rgba(200,169,126,.06);
}

/* ── Mosaic ───────────────────────────────────────────────────────────────── */

.fw__mosaic {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.625rem;
  height: auto;
}

@media (min-width: 768px) {
  .fw__mosaic {
    grid-template-columns: repeat(3, 1fr);
    height: 680px;
  }
}

.fw__col {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

/* Col hero — full height on desktop */
.fw__col--hero { height: 100%; }
.fw__col--stack { height: 100%; }
.fw__col--mixed { height: 100%; }

/* Cards */
.fw__card {
  position: relative;
  display: block;
  overflow: hidden;
  background-color: #141414;
  text-decoration: none;
  flex: 1;
}

@media (max-width: 767px) {
  .fw__card { aspect-ratio: 4 / 3; flex: none; }
}

.fw__card--hero { height: 100%; }
.fw__card--half { flex: 1; }
.fw__card--wide { flex: 1.4; }
.fw__card--sm   { flex: 1; }

/* Sub-row */
.fw__sub-row {
  display: flex;
  gap: 0.625rem;
  flex: 1;
}

.fw__sub-row .fw__card {
  flex: 1;
}

/* Image */
.fw__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* Overlay */
.fw__card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(8,8,8,.75) 0%,
    rgba(8,8,8,.15) 50%,
    transparent 100%
  );
  opacity: 0.6;
}

.fw__card:hover .fw__card-overlay {
  opacity: 1;
}

/* Card info */
.fw__card-info {
  position: absolute;
  bottom: 0.875rem;
  left: 0.875rem;
  right: 0.875rem;
}

.fw__card-cat {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.625rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(245,240,235,.75);
  background: rgba(8,8,8,.55);
  padding: 0.25rem 0.625rem;
}

/* ── Footer ──────────────────────────────────────────────────────────────── */

.fw__footer {
  margin-top: clamp(2rem, 3vw, 3rem);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.fw__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #C8A97E;
  text-decoration: none;
  border-bottom: 1px solid rgba(200,169,126,.3);
  padding-bottom: 0.25rem;
}

.fw__cta:hover {
  color: #D9C09D;
  border-bottom-color: #C8A97E;
}

.fw__footer-note {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 0.6875rem;
  color: #6B6B6B;
  margin: 0;
  letter-spacing: 0.04em;
}
</style>
