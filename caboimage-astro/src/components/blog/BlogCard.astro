---
// BlogCard.astro — Blog post preview card

export interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  heroImage?: string;
  heroImageAlt?: string;
  tags?: string[];
  category?: string;
}

const {
  title,
  description,
  slug,
  pubDate,
  heroImage,
  heroImageAlt,
  tags = [],
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-cabo-border hover:border-cabo-gold/30 transition-all duration-300 bg-cabo-card overflow-hidden">
  <!-- Image -->
  {heroImage && (
    <a href={`/blog/${slug}`} class="block overflow-hidden aspect-landscape" tabindex="-1" aria-hidden="true">
      <img
        src={heroImage}
        alt={heroImageAlt ?? title}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    </a>
  )}

  <!-- Content -->
  <div class="p-6">
    <!-- Date -->
    <time class="text-xs text-cabo-subtle font-sans tracking-wider uppercase" datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>

    <!-- Title -->
    <h3 class="font-serif text-xl text-cabo-white mt-3 mb-3 leading-snug group-hover:text-cabo-gold transition-colors duration-300">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>

    <!-- Excerpt -->
    <p class="text-cabo-muted text-sm font-sans leading-relaxed line-clamp-3 mb-4">
      {description}
    </p>

    <!-- Tags + Read more -->
    <div class="flex items-center justify-between">
      <div class="flex gap-2 flex-wrap">
        {tags.slice(0, 2).map(tag => (
          <span class="text-cabo-gold text-xs tracking-wider font-sans">#{tag}</span>
        ))}
      </div>
      <a
        href={`/blog/${slug}`}
        class="text-xs tracking-widest uppercase font-sans text-cabo-muted hover:text-cabo-gold transition-colors flex items-center gap-1"
      >
        Read
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</article>
