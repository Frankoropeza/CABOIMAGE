---
// ServiceCard.astro — Card for services grid

export interface Props {
  title: string;
  slug: string;
  tagline: string;
  heroImage: string;
  heroImageAlt: string;
  featured?: boolean;
  order?: number;
}

const { title, slug, tagline, heroImage, heroImageAlt, featured = false } = Astro.props;
---

<a
  href={`/services/${slug}`}
  class:list={[
    'group block relative overflow-hidden bg-cabo-card border border-cabo-border hover:border-cabo-gold/30 transition-all duration-500',
    featured ? 'md:col-span-2' : '',
  ]}
>
  <!-- Image -->
  <div class="relative overflow-hidden aspect-photo">
    <img
      src={heroImage}
      alt={heroImageAlt}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-cabo-black via-cabo-black/30 to-transparent" />
  </div>

  <!-- Content -->
  <div class="absolute bottom-0 left-0 right-0 p-6">
    {featured && (
      <span class="inline-block text-cabo-gold text-xs tracking-widest uppercase font-sans mb-2">
        Primary Service
      </span>
    )}
    <h3 class="font-serif text-xl text-cabo-white mb-1 group-hover:text-cabo-gold transition-colors duration-300">
      {title}
    </h3>
    <p class="text-cabo-muted text-sm font-sans italic">
      {tagline}
    </p>
    <div class="flex items-center gap-2 mt-3 text-cabo-gold text-xs tracking-wider uppercase font-sans opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <span>View Service</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </div>
  </div>
</a>
