---
// PageLayout.astro — Standard page layout with Header + Footer
// Used by: index, about, contact, gallery hub, blog index

import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/ui/WhatsAppButton.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article' | 'profile';
  canonicalURL?: string;
  noIndex?: boolean;
  schema?: object;
  // Page-specific options
  headerTransparent?: boolean;
  fullWidth?: boolean;
}

const {
  title,
  description,
  image,
  imageAlt,
  type,
  canonicalURL,
  noIndex,
  schema,
  headerTransparent = false,
  fullWidth = false,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  type={type}
  canonicalURL={canonicalURL}
  noIndex={noIndex}
  schema={schema}
>
  <Header transparent={headerTransparent} slot="default" />

  <main id="main-content" class={fullWidth ? '' : 'min-h-screen'}>
    <slot />
  </main>

  <Footer />

  <WhatsAppButton slot="whatsapp" />
</BaseLayout>
