---
// ServiceLayout.astro — Layout for individual service pages
// Used by: /services/[slug]

import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/ui/WhatsAppButton.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  canonicalURL?: string;
  schema?: object;
  // Service-specific
  serviceTitle: string;
  serviceSlug: string;
}

const {
  title,
  description,
  image,
  imageAlt,
  canonicalURL,
  schema,
  serviceTitle,
  serviceSlug,
} = Astro.props;

// Service page schema
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: serviceTitle,
  provider: {
    '@type': 'LocalBusiness',
    '@id': 'https://caboimage.com/#business',
    name: 'Cabo Image',
  },
  url: `https://caboimage.com/services/${serviceSlug}`,
  description,
  areaServed: {
    '@type': 'Place',
    name: 'Los Cabos, Baja California Sur, Mexico',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  canonicalURL={canonicalURL}
  schema={schema ?? serviceSchema}
>
  <Header transparent={true} slot="default" />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <WhatsAppButton slot="whatsapp" />
</BaseLayout>
