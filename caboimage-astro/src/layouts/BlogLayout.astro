---
// BlogLayout.astro — Layout for individual blog posts
// Used by: /blog/[slug]

import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import WhatsAppButton from '../components/ui/WhatsAppButton.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  pubDate: Date;
  author: string;
  tags?: string[];
  canonicalURL?: string;
}

const {
  title,
  description,
  image,
  imageAlt,
  pubDate,
  author,
  tags = [],
  canonicalURL,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = pubDate.toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: image ? `https://caboimage.com${image}` : 'https://caboimage.com/images/og-default.jpg',
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://caboimage.com/about',
  },
  publisher: {
    '@type': 'Organization',
    '@id': 'https://caboimage.com/#business',
    name: 'Cabo Image',
  },
  datePublished: isoDate,
  url: canonicalURL ?? Astro.url.href,
  keywords: tags.join(', '),
};
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  type="article"
  canonicalURL={canonicalURL}
  schema={articleSchema}
>
  <Header transparent={false} slot="default" />

  <main id="main-content" class="pt-24">
    <!-- Blog Hero -->
    {image && (
      <div class="relative w-full h-[50vh] min-h-[400px] overflow-hidden">
        <img
          src={image}
          alt={imageAlt ?? title}
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-cabo-black" />
      </div>
    )}

    <!-- Article -->
    <article class="max-w-content mx-auto px-6 py-16">

      <!-- Meta -->
      <div class="flex items-center gap-4 text-sm text-cabo-muted mb-6 font-sans">
        <time datetime={isoDate}>{formattedDate}</time>
        <span>·</span>
        <span>By {author}</span>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-2 flex-wrap">
              {tags.map(tag => (
                <span class="text-cabo-gold text-xs uppercase tracking-wider">#{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="font-serif text-display-md text-cabo-white mb-8 leading-tight">
        {title}
      </h1>

      <!-- Content -->
      <div class="prose prose-invert prose-lg prose-headings:font-serif prose-headings:text-cabo-white prose-p:text-cabo-muted prose-p:leading-relaxed prose-a:text-cabo-gold prose-strong:text-cabo-white max-w-none">
        <slot />
      </div>

      <!-- Back to blog -->
      <div class="mt-16 pt-8 border-t border-cabo-border">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-cabo-muted hover:text-cabo-gold transition-colors text-sm tracking-wider uppercase font-sans"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to Journal
        </a>
      </div>
    </article>
  </main>

  <Footer />

  <WhatsAppButton slot="whatsapp" />
</BaseLayout>
