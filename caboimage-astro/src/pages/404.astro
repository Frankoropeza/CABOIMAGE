---
// 404.astro — Custom not found page

import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Page Not Found | Cabo Image"
  description="The page you are looking for could not be found."
  noIndex={true}
>

  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="font-serif text-8xl text-cabo-border mb-8">404</p>
      <h1 class="font-serif text-display-sm text-cabo-white mb-4">
        Page Not Found
      </h1>
      <p class="text-cabo-muted font-sans mb-10 leading-relaxed">
        The page you are looking for may have been moved or does not exist.
        Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="px-8 py-3 bg-cabo-gold text-cabo-black text-xs tracking-widest uppercase font-sans hover:bg-cabo-gold-light transition-all duration-300"
        >
          Go Home
        </a>
        <a
          href="/gallery"
          class="px-8 py-3 border border-cabo-border text-cabo-muted text-xs tracking-widest uppercase font-sans hover:border-cabo-gold hover:text-cabo-gold transition-all duration-300"
        >
          View Gallery
        </a>
      </div>
    </div>
  </div>

</PageLayout>
